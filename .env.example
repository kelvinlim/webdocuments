# Copy to .env and edit. podman-compose reads this file automatically.

# --- Secrets (CHANGE THESE) ---
# Session cookie signing key for the host app.
SECRET_KEY=dev-insecure-change-me
# Shared JWT secret between the connector and the Document Server.
# Must match JWT_SECRET passed to the documentserver container.
ONLYOFFICE_JWT_SECRET=dev-onlyoffice-secret

# --- URLs ---
# Browser-facing base URL of the Document Server (where api.js is loaded from).
#   Local dev (DS published on :8090):        http://localhost:8090
#   Behind host nginx at /webdocs/ds:         /webdocs/ds
ONLYOFFICE_DS_PUBLIC_URL=http://localhost:8090

# Sub-path this connector is served under by the host nginx (FastAPI root_path).
#   Local dev (hit connector directly):       (leave empty)
#   Behind host nginx at /webdocs:            /webdocs
ROOT_PATH=

# --- References Cited bibliography ---
# CSL style for the generated "References Cited" document. Bare filename is
# resolved under app/styles/ (the .csl must exist there); empty = AMA default.
#   CSL_STYLE_PATH=vancouver.csl
CSL_STYLE_PATH=

# --- Demo auth ---
# Comma-separated username:password pairs. Demo only — plaintext, no hashing.
DEMO_USERS=demo:demo123
